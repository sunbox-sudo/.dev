#!/usr/bin/env bash

set -e  # Exit on error

echo "Starting Steam installation on Arch Linux..."

# Check if running with sudo
if [[ $EUID -ne 0 ]]; then
   echo "This script must be run with sudo"
   exit 1
fi

# Backup existing pacman.conf
cp /etc/pacman.conf /etc/pacman.conf.bak

# Enable the multilib repository
echo "Enabling the multilib repository..."

if ! grep -q "^\[multilib\]" /etc/pacman.conf; then
    echo -e "\n[multilib]\nInclude = /etc/pacman.d/mirrorlist" >> /etc/pacman.conf
else
    echo "Multilib repository is already enabled."
fi

# Update package database
echo "Updating package database..."
pacman -Sy --noconfirm

# Install required dependencies
echo "Installing dependencies..."
pacman -S --noconfirm \
    steam \
    lib32-glibc \
    lib32-gcc-libs \
    lib32-libxcrypt \
    ttf-liberation \
    wqy-zenhei \
    lib32-vulkan-icd-loader \
    vulkan-icd-loader \
    lib32-opengl-driver \
    opengl-driver

# Install Proton-GE (community version with latest compatibility)
echo "Installing Proton-GE for game compatibility..."
pacman -S --noconfirm proton-ge-custom || echo "Note: proton-ge-custom not found, Steam will use built-in Proton"

# Create a Steam launcher script in /usr/local/bin
echo "Creating Steam launcher script..."

cat > /usr/local/bin/steam-launcher << 'LAUNCHER'
#!/bin/sh
# Kill any existing Steam processes (graceful then forceful)
pkill -15 -u "$USER" -x steam 2>/dev/null || true
sleep 0.5
pkill -9 -u "$USER" -x steam 2>/dev/null || true
pkill -9 -u "$USER" -f steamwebhelper 2>/dev/null || true

# Choose XWayland on Wayland sessions
if [ -n "$WAYLAND_DISPLAY" ] && [ -z "$DISPLAY" ]; then
  exec steam --xwayland "$@"
else
  exec steam "$@"
fi
LAUNCHER

# Make the launcher script executable
chmod +x /usr/local/bin/steam-launcher

echo "Steam launcher script created at /usr/local/bin/steam-launcher"

# Create a desktop entry for Wofi and application menus
echo "Creating desktop entry for Wofi..."

cat > /usr/share/applications/steam-launcher.desktop << 'DESKTOP'
[Desktop Entry]
Type=Application
Name=Steam Launcher
Comment=Launch Steam with process cleanup and Wayland support
Exec=steam-launcher
Icon=steam
Categories=Game;Utility;
Terminal=false
DESKTOP

chmod 644 /usr/share/applications/steam-launcher.desktop

echo "Desktop entry created at /usr/share/applications/steam-launcher.desktop"

# Update desktop database
echo "Updating desktop database..."
update-desktop-database /usr/share/applications/

echo ""
echo "Installation complete!"
echo "You can now:"
echo "  • Launch Steam using: steam-launcher"
echo "  • Find it in Wofi: wofi -T drun"
echo "  • Find it in your application menu"

